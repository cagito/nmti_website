{
  "$schema": "figure-production-policy v1",
  "description": "Figure tier (FT) and allowed production methods. Source of truth for audit:figure-production.",
  "tiers": {
    "FT-A": {
      "label": "단면·설치 CAD",
      "allowedMethods": [
        "cad",
        "ai-reviewed"
      ],
      "forbiddenMethods": [
        "pillow",
        "agent-svg",
        "one-shot-ai"
      ]
    },
    "FT-B": {
      "label": "복합 개념도",
      "allowedMethods": [
        "cad",
        "ai-reviewed"
      ],
      "forbiddenMethods": [
        "pillow",
        "agent-svg",
        "one-shot-ai"
      ]
    },
    "FT-C": {
      "label": "블록·흐름·그래프·UI",
      "allowedMethods": [
        "pillow",
        "cad",
        "ai-reviewed"
      ],
      "forbiddenMethods": [
        "agent-svg"
      ]
    }
  },
  "methods": {
    "cad": "인간 CAD / Illustrator / Inkscape → PNG",
    "ai-reviewed": "ImageWorks 프롬프트 + redline + 인간 기술·출판 검수 → PNG",
    "pillow": "scripts/lib/*_draw.py (FT-C만)",
    "agent-svg": "에이전트·render-svg-figures (전면 금지)",
    "one-shot-ai": "redline·체크리스트 없이 1-shot GenerateImage (금지)"
  },
