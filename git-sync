#!/usr/bin/env bash
set -u

# ============================================================
# NMTI website git sync helper (Git Bash / macOS / Linux)
# - Pulls latest main branch every 60 seconds.
# - Press r during wait to run immediately.
# - Press q to quit.
# - Image transfer rule:
#     ChatGPT uploads text staging files such as *.webp.b64.part001.
#     git-sync merges parts and decodes them into same-name *.webp files locally.
# - This script does NOT render images on every sync cycle.
# ============================================================

BRANCH="${BRANCH:-main}"
WAIT_SECONDS="${WAIT_SECONDS:-60}"
IMAGE_ROOT="${IMAGE_ROOT:-assets/images/technology}"
RUN_BUILD="${RUN_BUILD:-1}"
RUN_VERIFY="${RUN_VERIFY:-0}"
DELETE_STAGING_AFTER_APPLY="${DELETE_STAGING_AFTER_APPLY:-0}"

cd "$(dirname "$0")"

decode_base64_to_file() {
  local src="$1"
  local dst="$2"
  if base64 --help 2>&1 | grep -q -- '--decode'; then
    base64 --decode "$src" > "$dst"
  else
    base64 -d "$src" > "$dst"
  fi
}

apply_text_staging() {
  echo "[2/5] Apply text-based WebP staging files..."

  if [ ! -d "$IMAGE_ROOT" ]; then
    echo "[SKIP] image root not found: $IMAGE_ROOT"
    return 0
  fi

  python - "$IMAGE_ROOT" "$DELETE_STAGING_AFTER_APPLY" <<'PY'
import base64
import hashlib
import json
import re
import sys
from pathlib import Path

root = Path(sys.argv[1])
delete_after = sys.argv[2] == "1"
changed = 0
processed_parts = set()

def is_webp(data):
    return len(data) >= 12 and data[:4] == b"RIFF" and data[8:12] == b"WEBP"

def meta_get(meta, *names):
    if not isinstance(meta, dict):
        return None
    for name in names:
        if name in meta:
            return meta[name]
    return None

def write_webp(target, data, meta, label):
    if not is_webp(data):
        raise ValueError("decoded bytes are not WebP RIFF/WEBP")
    expected_sha = meta_get(meta, "sha256", "sha256Hex", "SHA256")
    if expected_sha:
        actual_sha = hashlib.sha256(data).hexdigest()
        if actual_sha.lower() != str(expected_sha).lower():
            raise ValueError(f"SHA-256 mismatch: expected {expected_sha}, actual {actual_sha}")
    expected_size = meta_get(meta, "size", "bytes", "fileSize", "fileSizeBytes")
    if expected_size and len(data) != int(expected_size):
        raise ValueError(f"size mismatch: expected {expected_size} bytes, actual {len(data)} bytes")
    target.parent.mkdir(parents=True, exist_ok=True)
    backup = target.with_name(target.name + ".bak")
    had_existing = target.exists()
    if had_existing:
        backup.write_bytes(target.read_bytes())
    try:
        target.write_bytes(data)
        if backup.exists():
            backup.unlink()
        print(f"[WEBP] decoded {label} -> {target}")
    except Exception:
        if had_existing and backup.exists():
            target.write_bytes(backup.read_bytes())
            backup.unlink()
        raise

for manifest in root.rglob("*.webp.b64.parts.json"):
    try:
        target = manifest.with_name(manifest.name[:-len(".b64.parts.json")])
        meta = json.loads(manifest.read_text(encoding="utf-8"))
        pattern = re.compile(re.escape(target.name + ".b64.part") + r"(\d+)$")
        parts = []
        for candidate in manifest.parent.iterdir():
            match = pattern.match(candidate.name)
            if match and candidate.is_file():
                parts.append((int(match.group(1)), candidate))
        parts.sort(key=lambda item: item[0])
        if not parts:
            raise ValueError(f"no part files found for {manifest.name}")
        expected_parts = meta_get(meta, "parts", "partCount", "count")
        if expected_parts and len(parts) != int(expected_parts):
            raise ValueError(f"part count mismatch: expected {expected_parts}, actual {len(parts)}")
        b64 = "".join(part.read_text(encoding="utf-8") for _, part in parts)
        data = base64.b64decode(re.sub(r"\s+", "", b64), validate=True)
        write_webp(target, data, meta, str(manifest) + " parts")
        changed += 1
        for _, part in parts:
            processed_parts.add(part)
            if delete_after:
                part.unlink(missing_ok=True)
        if delete_after:
            manifest.unlink(missing_ok=True)
    except Exception as exc:
        print(f"[ERROR] failed part staging {manifest}: {exc}")

suffixes = [".webp.b64", ".webp.txt", ".img64", ".b64"]
for src in root.rglob("*"):
    if not src.is_file() or src in processed_parts:
        continue
    lower = src.name.lower()
    suffix = next((s for s in suffixes if lower.endswith(s)), None)
    if not suffix:
        continue
    try:
        base = src.name[:-len(suffix)]
        target = src.with_name(base + ".webp")
        b64 = re.sub(r"\s+", "", src.read_text(encoding="utf-8"))
        data = base64.b64decode(b64, validate=True)
        write_webp(target, data, None, str(src))
        changed += 1
        if delete_after:
            src.unlink(missing_ok=True)
    except Exception as exc:
        print(f"[ERROR] failed staging file {src}: {exc}")

print(f"[WEBP] staged replacements: {changed}")
PY
}

run_once() {
  echo
  echo "============================================================"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] git-sync start"
  echo "============================================================"

  echo "[1/5] Pull latest source..."
  if ! git pull origin "$BRANCH"; then
    echo "[ERROR] git pull failed."
    return 1
  fi

  apply_text_staging || return 1

  echo
  echo "[3/5] Install npm dependencies if node_modules is missing..."
  if [ ! -d "node_modules" ]; then
    npm install || echo "[WARN] npm install failed. Continue."
  fi

  echo
  echo "[4/5] Build images..."
  if [ "$RUN_BUILD" = "1" ]; then
    npm run build:images || echo "[WARN] npm run build:images failed. Continue."
  else
    echo "[SKIP] RUN_BUILD=0"
  fi

  echo
  echo "[5/5] Verify content..."
  if [ "$RUN_VERIFY" = "1" ]; then
    npm run verify:content || echo "[WARN] npm run verify:content failed. Continue."
  else
    echo "[SKIP] RUN_VERIFY=0"
  fi

  echo
  echo "[STATUS]"
  git status --short

  echo
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] git-sync done"
}

while true; do
  run_once
  echo
  echo "[WAIT] $WAIT_SECONDS seconds. Press r = run now, q = quit."
  read -r -t "$WAIT_SECONDS" -n 1 key || key="r"
  echo
  case "$key" in
    q|Q) echo "git-sync stopped."; exit 0 ;;
    r|R|"") continue ;;
    *) continue ;;
  esac
done
